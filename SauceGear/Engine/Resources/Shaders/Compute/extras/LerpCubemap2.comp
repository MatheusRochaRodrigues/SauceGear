#version 430

// Tamanho do work group
//layout(local_size_x = 8, local_size_y = 4, local_size_z = 1) in;
layout(local_size_x = 8, local_size_y = 8, local_size_z = 1) in;

// Cubemaps de entrada (HDR)
layout(binding = 0) uniform samplerCube prevCube;
layout(binding = 1) uniform samplerCube nextCube;

// Cubemap de saÝda
layout(binding = 2, rgba16f) uniform imageCube outCube;

// ParÔmetros de interpolaþÒo
uniform float lerpFactor;   // 0.0 -> prevCube, 1.0 -> nextCube
uniform int mipLevel;       // NÝvel do mipmap

// Converte (face, uv) -> direþÒo 3D para amostrar cubemap
vec3 uvToDir(int face, vec2 uv)
{
    float u = uv.x * 2.0 - 1.0; // -1..1
    float v = uv.y * 2.0 - 1.0;

    if(face == 0) return normalize(vec3( 1.0, -v, -u)); // +X
    if(face == 1) return normalize(vec3(-1.0, -v,  u)); // -X
    if(face == 2) return normalize(vec3( u,  1.0,  v)); // +Y
    if(face == 3) return normalize(vec3( u, -1.0, -v)); // -Y
    if(face == 4) return normalize(vec3( u, -v,  1.0)); // +Z
    if(face == 5) return normalize(vec3(-u, -v, -1.0)); // -Z

    return vec3(0.0,0.0,0.0);
}

void main()
{
    uvec2 gid = gl_GlobalInvocationID.xy; // Ýndice 2D
    ivec2 texSize = textureSize(prevCube, mipLevel).xy;

    if(gid.x >= uint(texSize.x) || gid.y >= uint(texSize.y)) return;

    // Loop por cada face do cubemap
    for(int face = 0; face < 6; ++face)
    {
        // UV do centro do texel
        vec2 uv = (vec2(gid) + 0.5) / vec2(texSize);

        // DireþÒo correta da face
        vec3 dir = uvToDir(face, uv);

        // Amostra os cubemaps
        vec3 colorPrev = textureLod(prevCube, dir, float(mipLevel)).rgb;
        vec3 colorNext = textureLod(nextCube, dir, float(mipLevel)).rgb;

        // Interpola
        vec3 lerpedColor = mix(colorPrev, colorNext, lerpFactor);

        // Escreve no cubemap de saÝda
        imageStore(outCube, ivec3(gid, face), vec4(lerpedColor,1.0));

        // Sincroniza invocaþ§es do mesmo work group (opcional aqui, mas seguro)
        barrier();
    }

    // Garante que todas as writes em outCube fiquem visÝveis fora do compute
    memoryBarrierImage();
}
