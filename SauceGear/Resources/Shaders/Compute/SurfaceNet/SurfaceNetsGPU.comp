#version 450 
layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;
 
uniform int uDim; // dimensŃo do grid (n·mero de voxels)
uniform float uVoxelSize;   // tamanho do voxel definido pelo CPU
uniform int uPass; // 1 = criar vertices, 2 = criar tris                Extra 3 to debug

// Adiciona deslocamento global e escala total
uniform vec3 uOffset;       // posińŃo global do chunk no mundo 


// SDF input
layout(std430, binding = 0) readonly buffer SDF { float sdf[]; };

// Output buffers
layout(std430, binding = 1) writeonly buffer Positions { vec4 positions[]; };
layout(std430, binding = 2) writeonly buffer Normals { vec4 normals[]; };
layout(std430, binding = 3) writeonly buffer Indices { uint indices[]; }; 

// Stride->vertex index table (indexed by linear cell index)
layout(std430, binding = 4) buffer StrideToIndex { uint stride_to_index[]; };     // expected length = uDim*uDim*uDim  

// Counters: vertexCount, indexCount (atomically incremented)
layout(std430, binding = 5) buffer Counters {
    uint vertexCount;
    uint indexCount;
};



//--------------------APENAS PARA DEBUG-----------------------------------
// no topo (ap¾s os outros buffers)
layout(std430, binding = 6) buffer DebugPoints {
    vec4 debug_positions[]; // xyz = posińŃo, w = intensidade
};
layout(std430, binding = 7) buffer DebugColors {
    vec4 debug_colors[]; // rgb = cor, a = unused
};
// --- Debug Counter ---
layout(std430, binding = 8) buffer DebugCounters {
    uint debugCount;
};
//---------------------------------------------------------------------




// constants
const uint NULL_VERTEX = 0xFFFFFFFFu;

const vec3 CUBE_CORNERS[8] = vec3[8](
    vec3(0,0,0), vec3(1,0,0), vec3(0,1,0), vec3(1,1,0),
    vec3(0,0,1), vec3(1,0,1), vec3(0,1,1), vec3(1,1,1)
);

const int CUBE_EDGES[12][2] = int[12][2](
    int[2](0,1), int[2](1,3), int[2](3,2), int[2](2,0),
    int[2](4,5), int[2](5,7), int[2](7,6), int[2](6,4),
    int[2](0,4), int[2](1,5), int[2](2,6), int[2](3,7)
);

uint linearize3(ivec3 v) {
    return uint(v.x) + uint(v.y) * uint(uDim) + uint(v.z) * uint(uDim) * uint(uDim);
}

// estimate intersection along edge (same as CPU)
vec3 estimate_surface_edge_intersection(int c1, int c2, float v1, float v2){
    float t = v1 / (v1 - v2);
    return mix(CUBE_CORNERS[c1], CUBE_CORNERS[c2], t);
}

// centroid of edge intersections (same as CPU)
vec3 centroid_of_edge_intersections(float cornerSDF[8]){
    vec3 sum = vec3(0.0);
    int count = 0;
    for (int i = 0; i < 12; ++i) {
        int a = CUBE_EDGES[i][0];
        int b = CUBE_EDGES[i][1];
        if ((cornerSDF[a] < 0.0) != (cornerSDF[b] < 0.0)) {
            sum += estimate_surface_edge_intersection(a, b, cornerSDF[a], cornerSDF[b]);
            count++;
        }
    }
    // Guard: in CPU path count>0 because cube intersects surface
    return sum / float(max(count, 1));
}

// analytical trilinear gradient (same as CPU)
vec3 SDFGradient(float cornerSDF[8], vec3 s) {
    float sx = s.x;
    float sy = s.y;
    float sz = s.z;
    float nx = 1.0 - sx;
    float ny = 1.0 - sy;
    float nz = 1.0 - sz;

    vec3 grad = vec3(0.0);

    for (int i = 0; i < 8; ++i) {
        //get each corner the cube
        int bx = (i & 1) != 0 ? 1 : 0;
        int by = (i & 2) != 0 ? 1 : 0;
        int bz = (i & 4) != 0 ? 1 : 0;

        float wx = bx != 0 ? sx : nx;
        float wy = by != 0 ? sy : ny;
        float wz = bz != 0 ? sz : nz;

        float dw_dx = (bx != 0 ? 1.0 : -1.0) * wy * wz;
        float dw_dy = (by != 0 ? 1.0 : -1.0) * wx * wz;
        float dw_dz = (bz != 0 ? 1.0 : -1.0) * wx * wy;

        float v = cornerSDF[i];
        grad.x += v * dw_dx;
        grad.y += v * dw_dy;
        grad.z += v * dw_dz;
    }

    grad /= (uVoxelSize != 0.0 ? uVoxelSize : 1.0);

    float len2 = dot(grad, grad);
    if (len2 < 1e-12) {
        // fallback approximations (same as CPU)
        vec3 g = vec3(
            ((cornerSDF[1] + cornerSDF[3] + cornerSDF[5] + cornerSDF[7]) - (cornerSDF[0] + cornerSDF[2] + cornerSDF[4] + cornerSDF[6])) * 0.5,
            ((cornerSDF[2] + cornerSDF[3] + cornerSDF[6] + cornerSDF[7]) - (cornerSDF[0] + cornerSDF[1] + cornerSDF[4] + cornerSDF[5])) * 0.5,
            ((cornerSDF[4] + cornerSDF[5] + cornerSDF[6] + cornerSDF[7]) - (cornerSDF[0] + cornerSDF[1] + cornerSDF[2] + cornerSDF[3])) * 0.5
        );
        grad = g;
        if (dot(grad, grad) < 1e-12) grad = vec3(0.0, 1.0, 0.0);
    }
    return normalize(grad);
}

float distance2(vec3 a, vec3 b) {
    vec3 d = a - b;
    return dot(d, d);               //return d.x * d.x + d.y * d.y + d.z * d.z;
} 

// maybe_make_quad: praticamente a mesma l¾gica do CPU
void maybe_make_quad(uint p1, uint p2, uint axis_b_stride, uint axis_c_stride, float cornerSDF[8]) {
    float d1 = sdf[p1];
    float d2 = sdf[p2];
    bool neg1 = (d1 < 0.0);
    bool neg2 = (d2 < 0.0);

    bool negative_face;
    if (neg1 && !neg2) negative_face = false;
    else if (!neg1 && neg2) negative_face = true;
    else return; // no face

    uint v1 = stride_to_index[p1];
    uint v2 = stride_to_index[p1 - axis_b_stride];
    uint v3 = stride_to_index[p1 - axis_c_stride];
    uint v4 = stride_to_index[p1 - axis_b_stride - axis_c_stride];

    if (v1 == NULL_VERTEX || v2 == NULL_VERTEX || v3 == NULL_VERTEX || v4 == NULL_VERTEX)
        return;

    vec3 pos1 = positions[v1].xyz;
    vec3 pos2 = positions[v2].xyz;
    vec3 pos3 = positions[v3].xyz;
    vec3 pos4 = positions[v4].xyz;

    uint quad[6];
    if (distance2(pos1, pos4) < distance2(pos2, pos3)) {
        if (negative_face) {
            quad[0]=v1; quad[1]=v4; quad[2]=v2;
            quad[3]=v1; quad[4]=v3; quad[5]=v4;
        } else {
            quad[0]=v1; quad[1]=v2; quad[2]=v4;
            quad[3]=v1; quad[4]=v4; quad[5]=v3;
        }
    } else {
        if (negative_face) {
            quad[0]=v2; quad[1]=v3; quad[2]=v4;
            quad[3]=v2; quad[4]=v1; quad[5]=v3;
        } else {
            quad[0]=v2; quad[1]=v4; quad[2]=v3;
            quad[3]=v2; quad[4]=v3; quad[5]=v1;
        }
    }

    // append indices atomically: reserve 6 slots
    uint idx = atomicAdd(indexCount, 6u);
    // write directly into indices array
    for (int i = 0; i < 6; ++i) {
        indices[idx + uint(i)] = quad[i];
    }
}

// build quads for the given cell stride (linear index)
void make_all_quads(ivec3 cell, float cornerSDF[8], uint baseStride) {
    uint strideX = 1u;
    uint strideY = uint(uDim);
    uint strideZ = uint(uDim) * uint(uDim);

    // matches CPU conditions (only create quads when neighbor indices in bounds)
    if (cell.y > 0 && cell.z > 0 && cell.x < uDim - 1) maybe_make_quad(baseStride, baseStride + strideX, strideY, strideZ, cornerSDF);
    if (cell.x > 0 && cell.z > 0 && cell.y < uDim - 1) maybe_make_quad(baseStride, baseStride + strideY, strideZ, strideX, cornerSDF);
    if (cell.x > 0 && cell.y > 0 && cell.z < uDim - 1) maybe_make_quad(baseStride, baseStride + strideZ, strideX, strideY, cornerSDF);
}

// --- Main ---
void main() {
    ivec3 cell = ivec3(gl_GlobalInvocationID.xyz);
     
    //   uDim(Voxels) == uDimCells + 1   =>   uDim - 1 == uDimCells   // only iterate valid cells (cells are uDim-1 in each axis)
    //if (cell.x > uDim + 1  || cell.y > uDim + 1  || cell.z > uDim + 1) return; 
    //if (cell.x >= uDim - 1 || cell.y >= uDim - 1 || cell.z >= uDim - 1) return; 
    if (cell.x > uDim - 1 || cell.y > uDim - 1 || cell.z > uDim - 1) return; 

    float cornerVal[8];
    int numNeg = 0;
    for (int i = 0; i < 8; ++i) {
        ivec3 c = cell + ivec3(CUBE_CORNERS[i]);
        uint li = linearize3(c);
        cornerVal[i] = sdf[li];
        if (cornerVal[i] < 0.0) ++numNeg;
    }

    uint stride = linearize3(cell);

    if (numNeg == 0 || numNeg == 8) { 
        stride_to_index[stride] = NULL_VERTEX;   // mark as empty
        return;
    }
     
    if(uPass == 1){
        // compute vertex position & normal (same as CPU)
        vec3 cpos = centroid_of_edge_intersections(cornerVal);
        vec3 normal = SDFGradient(cornerVal, cpos);

        // reserve a vertex index atomically
        uint outIndex = atomicAdd(vertexCount, 1u);
        // store mapping stride -> vertex index (same indexing as CPU)
        stride_to_index[stride] = outIndex;

        // write position and normal
        //positions[outIndex] = vec4(vec3(cell) + cpos, 1.0);      //positions[outIndex] = vec4(vec3(cell)*uVoxelSize + cpos + uOffset, 1.0);

        //uVoxelSize - converte do Ēndice para metros (ou unidades de mundo).
        //uWorldScale - aplica escala global do mundo (caso queira mundos grandes/pequenos).
        //uOffset - move para posińŃo global do chunk no mundo.
        vec3 worldPos = (vec3(cell) + cpos) * uVoxelSize + uOffset; 
        positions[outIndex] = vec4(worldPos, 1.0);
        

        normals[outIndex] = vec4(normal, 1.0);
         
    } else if(uPass == 2){
        // create quads/triangles connecting to neighbors (baseStride is linear cell index)
        make_all_quads(cell, cornerVal, stride);
    }


    
    //--------------------APENAS PARA DEBUG-----------------------------------
    //to Debug -----------------------------------------------------------
    else if(uPass == 3){ 

            // Visualizar SDF dos cantos
        for (int i = 0; i < 8; ++i) {
            vec3 cornerPos = (vec3(cell) + CUBE_CORNERS[i]) * uVoxelSize + uOffset;

            float val = cornerVal[i];
            float normVal = clamp(abs(val) * 0.2, 0.0, 1.0); // intensidade

            // cor: azul (negativo), vermelho (positivo)
            vec3 color = val < 0.0 ? vec3(0.0, 0.3 + 0.7 * normVal, 1.0) 
                                   : vec3(1.0, 0.2 * (1.0 - normVal), 0.0);

            // adiciona no buffer (at¶mico)
            uint id = atomicAdd(debugCount, 1u); // reutiliza counter indexCount
            debug_positions[id] = vec4(cornerPos, val);
            debug_colors[id] = vec4(color, 1.0);
        }

        // Visualizar interseń§es nas arestas
        for (int i = 0; i < 12; ++i) {
            int a = CUBE_EDGES[i][0];
            int b = CUBE_EDGES[i][1];
            if ((cornerVal[a] < 0.0) != (cornerVal[b] < 0.0)) {
                vec3 edgePos = (vec3(cell) + estimate_surface_edge_intersection(a, b, cornerVal[a], cornerVal[b])) * uVoxelSize + uOffset;
                uint id = atomicAdd(debugCount, 1u);
                debug_positions[id] = vec4(edgePos, 1.0);
                debug_colors[id] = vec4(0.0, 1.0, 0.0, 1.0); // verde = aresta cortada
            }
        }

        // Para cada aresta do cubo
        /*
        for(int i = 0; i < 12; ++i){
            int a = CUBE_EDGES[i][0];
            int b = CUBE_EDGES[i][1];

            vec3 pa = (vec3(cell) + CUBE_CORNERS[a]) * uVoxelSize + uOffset;
            vec3 pb = (vec3(cell) + CUBE_CORNERS[b]) * uVoxelSize + uOffset;

            bool active1 = (cornerVal[a] < 0.0) != (cornerVal[b] < 0.0);

            vec3 color = active1 ? vec3(0.0, 1.0, 0.0) : vec3(1.0, 1.0, 1.0);

            uint id = atomicAdd(debugCount, 2u); // 2 pontos por linha
            debug_positions[id] = vec4(pa, 1.0);
            debug_positions[id + 1] = vec4(pb, 1.0);

            debug_colors[id] = vec4(color, 1.0);
            debug_colors[id + 1] = vec4(color, 1.0);
        }
        */
         
    }
    //----------------------------------------------------------------------------- 


}
