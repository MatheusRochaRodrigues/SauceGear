// Permutation helpers
int hash(int x, int y, int z) {
    return perm[(perm[(perm[x & 255] + y) & 255] + z) & 255];
}

float fade(float t) { return t * t * t * (t * (t * 6 - 15) + 10); }
float lerp(float a, float b, float t) { return a + t * (b - a); }
float grad(int hash, float x, float y, float z) {
    int h = hash & 15;
    float u = h < 8 ? x : y;
    float v = h < 4 ? y : (h == 12 || h == 14 ? x : z);
    return ((h & 1) == 0 ? u : -u) + ((h & 2) == 0 ? v : -v);
}

// Perlin noise 3D
float perlinNoise(vec3 p) {
    ivec3 pi = ivec3(floor(p)) & 255;
    vec3 pf = fract(p);
    vec3 f = vec3(fade(pf.x), fade(pf.y), fade(pf.z));

    int A  = hash(pi.x, pi.y, pi.z);
    int AA = hash(pi.x, pi.y, pi.z);
    int AB = hash(pi.x, pi.y, pi.z+1);
    int B  = hash(pi.x+1, pi.y, pi.z);
    int BA = hash(pi.x+1, pi.y, pi.z);
    int BB = hash(pi.x+1, pi.y, pi.z+1);

    float x1 = lerp(grad(A, pf.x, pf.y, pf.z), grad(B, pf.x-1.0, pf.y, pf.z), f.x);
    float x2 = lerp(grad(AA, pf.x, pf.y-1.0, pf.z), grad(BA, pf.x-1.0, pf.y-1.0, pf.z), f.x);
    float y1 = lerp(x1, x2, f.y);

    float x3 = lerp(grad(AB, pf.x, pf.y, pf.z-1.0), grad(BB, pf.x-1.0, pf.y, pf.z-1.0), f.x);
    float x4 = lerp(grad(AA, pf.x, pf.y-1.0, pf.z-1.0), grad(BA, pf.x-1.0, pf.y-1.0, pf.z-1.0), f.x);
    float y2 = lerp(x3, x4, f.y);

    return lerp(y1, y2, f.z);
}

// Fractal Perlin
float fractalPerlin(vec3 p) {
    float sum = 0.0;
    float amp = 1.0;
    float freq = 1.0;
    for(int i=0;i<5;i++) {
        sum += perlinNoise(p*freq)*amp;
        freq *= 2.0;
        amp *= 0.5;
    }
    return sum;
}

// Worley (cellular) noise
float worleyNoise(vec3 p) {
    vec3 pi = floor(p);
    float minDist = 1e10;
    for(int x=-1;x<=1;x++)
        for(int y=-1;y<=1;y++)
            for(int z=-1;z<=1;z++) {
                vec3 neighbor = pi + vec3(x,y,z);
                vec3 point = neighbor + vec3(fract(sin(dot(neighbor, vec3(12.989,78.233,45.164)))*43758.5453));
                float d = length(point-p);
                minDist = min(minDist,d);
            }
    return minDist;
}

void main() {
    ivec3 cell = ivec3(gl_GlobalInvocationID.xyz);
    if(any(greaterThanEqual(cell, ivec3(uDim)))) return;

    vec3 pos = vec3(cell) * uVoxelSize + uOffset;

    // --- altura do terreno ---
    float height = fractalPerlin(pos*0.05)*5.0; 
    // --- cavernas / detalhes ---
    float caves = worleyNoise(pos*0.1)*2.0 - 1.0;

    // --- SDF: negativo dentro, 0 superfície, positivo fora ---
    float distToSurface = pos.y - height + caves - uIsoLevel;

    int idx = cell.x + cell.y * uDim + cell.z * uDim * uDim;
    sdf[idx] = distToSurface;
}
