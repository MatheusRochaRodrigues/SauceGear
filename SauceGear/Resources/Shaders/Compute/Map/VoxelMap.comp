#version 450
layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;

uniform int uDim;
uniform float uVoxelSize;
uniform vec3 uOffset;           //   deslocamento
uniform float uIsoLevel;

// output SDF
layout(std430, binding = 0) buffer SDF { float sdf[]; };

